# Application
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Database
DATABASE_URL=file:./tradediary.sqlite
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/tradediary

# Authentication (if applicable)
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# Optional: external broker API keys
# BROKER_API_KEY=
# BROKER_API_SECRET=
